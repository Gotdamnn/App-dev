# PatientPulse Environment Configuration
# Works for BOTH local development and Azure production

# Node Environment (set to 'production' in Azure)
NODE_ENV=development

# Server Configuration (PORT auto-detects in Azure)
PORT=3001
HOST=localhost
APP_URL=http://localhost:3001

# PostgreSQL Database (Supabase Pooler)
DB_USER=postgres.eeubefsvavmguwmapgpi
DB_PASSWORD=Carlzabala@123
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_SSL=true

# CORS Configuration (allow both localhost for dev and Azure for prod)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:50071,http://localhost:50071,https://patientpulse-cvfzbpbpbuhve8gc.southeastasia-01.azurewebsites.net

# Admin Credentials
ADMIN_EMAIL=admin@patientpulse.com
ADMIN_PASSWORD=admin123

# API Configuration
API_VERSION=1.0
API_PREFIX=/api

# Logging
LOG_LEVEL=info
LOG_FILE=server.log

# Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Session
SESSION_SECRET=dev_session_secret_key_change_in_production

# SMTP Configuration for Email Verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=patientpulse2026@gmail.com
SMTP_PASSWORD=mkxxyfbvqeqzwxdd
SMTP_FROM_EMAIL=patientpulse2026@gmail.com
SMTP_FROM_NAME=PatientPulse

# Email Configuration (alternative names)
EMAIL_USER=patientpulse2026@gmail.com
EMAIL_PASSWORD=mkxxyfbvqeqzwxdd

# Mobile App URL
MOBILE_APP_URL=http://localhost:3001

# Twilio (optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

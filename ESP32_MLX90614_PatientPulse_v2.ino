// ===== FUNCTION PROTOTYPES =====
void setupDisplay();
void setupSensor();
void setupWiFi();
void connectToWiFi();
void updateSensorReadings();
void sendTemperatureToAPI(float tempC, String status);
String classifyTemperature(float tempC);
void displayTemperatureScreen(float tempC, String status);
void displaySplashScreen();
void scanI2CBus(const char* busName, TwoWire& wire);

void scanI2CBus(const char* busName, TwoWire& wire) {
    Serial.print("Scanning ");
    Serial.print(busName);
    Serial.println("...");
    
    int count = 0;
    for (byte address = 1; address < 127; address++) {
        wire.beginTransmission(address);
        byte error = wire.endTransmission();
        
        if (error == 0) {
            Serial.print("  ✓ Found device at 0x");
            if (address < 16) Serial.print("0");
            Serial.println(address, HEX);
            count++;
        }
    }
    
    if (count == 0) {
        Serial.println("  ✗ No devices found!");
    }
}

// ==============================================================================
void setup() {
    Serial.begin(115200);
    delay(1000);
    
    Serial.println("\n\n=== PatientPulse MLX90614 Temperature Monitor ===\n");
    
    // Initialize I2C Bus 0 (OLED on GPIO 18, 16)
    Serial.print("Initializing I2C Bus 0 (OLED)...");
    pinMode(OLED_SDA_PIN, INPUT_PULLUP);  // Enable internal pull-ups
    pinMode(OLED_SCL_PIN, INPUT_PULLUP);
    I2C_OLED.begin(OLED_SDA_PIN, OLED_SCL_PIN, 100000);
    Serial.println(" ✓");
    
    // Initialize I2C Bus 1 (MLX90614 on GPIO 21, 22)
    Serial.print("Initializing I2C Bus 1 (MLX90614)...");
    pinMode(MLX_SDA_PIN, INPUT_PULLUP);  // Enable internal pull-ups
    pinMode(MLX_SCL_PIN, INPUT_PULLUP);
    I2C_MLX.begin(MLX_SDA_PIN, MLX_SCL_PIN, 100000);
    Serial.println(" ✓");
    
    // Scan both I2C buses to see what devices are connected
    Serial.println("\n=== I2C Device Scan ===");
    delay(100);
    scanI2CBus("I2C Bus 0 (OLED pins GPIO 18, 16)", I2C_OLED);
    delay(100);
    scanI2CBus("I2C Bus 1 (MLX90614 pins GPIO 21, 22)", I2C_MLX);
    Serial.println();
    
    // Initialize display
    Serial.print("Initializing OLED display...");
    setupDisplay();
    Serial.println(" ✓");
    
    // Show splash screen with logo
    displaySplashScreen();
    delay(3000);  // Show for 3 seconds
    
    // Initialize temperature sensor
    Serial.print("Initializing MLX90614 sensor...");
    setupSensor();
    Serial.println(" ✓");
    
    // Initialize WiFi
    Serial.print("Initializing WiFi...");
    setupWiFi();
    Serial.println(" ✓");
    
    // Connect to WiFi
    connectToWiFi();
    
    Serial.println("\n=== Initialization Complete ===\n");
}

// ==============================================================================
void loop() {
    // Check WiFi connection status
    if (WiFi.status() != WL_CONNECTED) {
        isWiFiConnected = false;
        if (millis() % 10000 < 500) {  // Try reconnect every 10 seconds
            Serial.println("WiFi disconnected. Attempting to reconnect...");
            connectToWiFi();
        }
    } else {
        isWiFiConnected = true;
    }
    
    // Update sensor readings and send data at interval
    unsigned long currentMillis = millis();
    if (currentMillis - previousMillis >= interval) {
        previousMillis = currentMillis;
        updateSensorReadings();
    }
    
    delay(100);  // Small delay to prevent watchdog timeout
}


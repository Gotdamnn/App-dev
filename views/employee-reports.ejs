<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Reports - PatientPulse</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/employee-reports.css">
    <link href="https://fonts.googleapis.com/css?family=Inter:400,500,600,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/sidebar', { activePage: 'employee-reports' }) %>

    <div class="main">
        <div class="page-header">
            <div>
                <h1>Employee Reports</h1>
                <div class="report-count" id="reportCount">Loading...</div>
            </div>
            <button class="add-report-btn"><i class="fas fa-plus"></i> New Report</button>
        </div>

        <div class="report-controls">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search by employee name, department...">
            </div>
            <div class="filters">
                <select class="filter-select" id="statusFilter">
                    <option>All Status</option>
                    <option>Open</option>
                    <option>In Progress</option>
                    <option>Under Review</option>
                    <option>Resolved</option>
                    <option>Closed</option>
                </select>
                <select class="filter-select" id="severityFilter">
                    <option>All Severity</option>
                    <option>Low</option>
                    <option>Medium</option>
                    <option>High</option>
                    <option>Critical</option>
                </select>
                <select class="filter-select" id="typeFilter">
                    <option>All Types</option>
                    <option>Complaint</option>
                    <option>Incident</option>
                    <option>Disciplinary</option>
                    <option>Performance</option>
                </select>
            </div>
        </div>

        <div class="table-container">
            <table class="reports-table">
                <thead>
                    <tr>
                        <th><input type="checkbox"></th>
                        <th>Report ID</th>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Type</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Reported By</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="reportsTableBody">
                    <!-- Report data will be loaded dynamically -->
                </tbody>
            </table>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
    <script src="/js/employee-reports.js"></script>
</body>
</html>

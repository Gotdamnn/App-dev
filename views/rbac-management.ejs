        // Close edit modal
        function closeEditModal() {
            document.getElementById('editModal').classList.remove('active');
            editingAdminId = null;
        }

        // Variables for permission overrides
        let editingStaffIdOverrides = null;
        let editingStaffEmailOverrides = null;
        let staffPermissionOverrides = {}; // Track permission overrides like {permissionId: 'grant'|'revoke'|null}

        // Open permission overrides modal
        async function openOverridesModal(staffId, email, staffName, role, roleClass) {
            editingStaffIdOverrides = staffId;
            editingStaffEmailOverrides = email;
            staffPermissionOverrides = {};

            // Set header info
            document.getElementById('overrideStaffName').textContent = staffName;
            const roleBadge = document.getElementById('overrideStaffRole');
            roleBadge.className = `role-badge ${roleClass}`;
            roleBadge.textContent = role;

            // Load and display all available permissions
            try {
                const response = await fetch(`/api/staff/${staffId}/permissions?email=${encodeURIComponent(email)}`);
                
                if (!response.ok) {
                    if (response.status === 404) {
                        showAlert('Staff member not found. Please try refreshing the page.', 'error');
                    } else {
                        throw new Error(`HTTP ${response.status}`);
                    }
                    return;
                }

                const data = await response.json();
                const permissions = data.staff.permissions;

                // Render permissions override list
                const list = document.getElementById('permissionsOverrideList');
                list.innerHTML = '';

                // Group by category
                const byCategory = {};
                permissions.forEach(perm => {
                    if (!byCategory[perm.category]) byCategory[perm.category] = [];
                    byCategory[perm.category].push(perm);
                });

                for (const [category, perms] of Object.entries(byCategory)) {
                    perms.forEach(perm => {
                        const status = perm.permission_type || 'none';
                        const overrideItem = document.createElement('div');
                        overrideItem.className = 'permission-override-item';
                        overrideItem.innerHTML = `
                            <div>
                                <div class="permission-override-item-name">${perm.permission_name}</div>
                                <div class="permission-override-item-category">${perm.category}</div>
                            </div>
                            <div class="permission-override-controls">
                                <span class="override-status-badge ${status}">${status === 'grant' ? 'Granted' : status === 'revoke' ? 'Revoked' : 'Default'}</span>
                                <div class="override-btn-group">
                                    <button class="override-action-btn grant-btn" title="Grant permission" 
                                            onclick="setPermissionOverride(${perm.permission_id}, 'grant')">
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button class="override-action-btn revoke-btn" title="Revoke permission" 
                                            onclick="setPermissionOverride(${perm.permission_id}, 'revoke')">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <button class="override-action-btn clear-btn" title="Clear override" 
                                            onclick="setPermissionOverride(${perm.permission_id}, null)">
                                        <i class="fas fa-sync"></i>
                                    </button>
                                </div>
                            </div>
                        `;
                        list.appendChild(overrideItem);
                    });
                }

                document.getElementById('overridesModal').classList.add('active');
            } catch (err) {
                console.error('Error loading permissions:', err);
                showAlert('Error loading permissions. Please try again.', 'error');
            }
        }

        //Set permission override tracking
        function setPermissionOverride(permissionId, status) {
            staffPermissionOverrides[permissionId] = status;
            
            // Update UI badge for this permission
            const items = document.querySelectorAll('.permission-override-item');
            items.forEach(item => {
                const btn = item.querySelector(`[onclick*="${permissionId}"]`);
                if (btn) {
                    const badge = item.querySelector('.override-status-badge');
                    badge.className = `override-status-badge ${status || 'none'}`;
                    badge.textContent = status === 'grant' ? 'Granted' : status === 'revoke' ? 'Revoked' : 'Default';
                }
            });
        }

        // Close overrides modal
        function closeOverridesModal() {
            document.getElementById('overridesModal').classList.remove('active');
            editingStaffIdOverrides = null;
            staffPermissionOverrides = {};
        }

        // Save permission overrides
        async function saveOverrides() {
            try {
                for (const [permissionId, status] of Object.entries(staffPermissionOverrides)) {
                    if (status === 'grant') {
                        const response = await fetch(`/api/staff/${editingStaffIdOverrides}/permissions/grant?email=${encodeURIComponent(editingStaffEmailOverrides)}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ permissionId: parseInt(permissionId) })
                        });
                        if (!response.ok) throw new Error('Failed to grant permission');
                    } else if (status === 'revoke') {
                        const response = await fetch(`/api/staff/${editingStaffIdOverrides}/permissions/revoke?email=${encodeURIComponent(editingStaffEmailOverrides)}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ permissionId: parseInt(permissionId) })
                        });
                        if (!response.ok) throw new Error('Failed to revoke permission');
                    } else if (status === null) {
                        // Clear override - delete from database
                        const response = await fetch(`/api/staff/${editingStaffIdOverrides}/permissions/revoke?email=${encodeURIComponent(editingStaffEmailOverrides)}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ permissionId: parseInt(permissionId) })
                        });
                        if (!response.ok) console.warn('Could not clear override');
                    }
                }
                
                showAlert('Permission overrides saved successfully!', 'success');
                closeOverridesModal();
                renderStaffTable();
            } catch (err) {
                showAlert('Error saving overrides: ' + err.message, 'error');
            }
        }

        // Reset all overrides for staff member
        async function resetAllOverrides() {
            showConfirmation(
                'Reset Permission Overrides',
                'Are you sure you want to reset all permission overrides for this staff member? They will use role-based permissions.',
                async () => {
                    try {
                        const response = await fetch(`/api/staff/${editingStaffIdOverrides}/permissions/reset?email=${encodeURIComponent(editingStaffEmailOverrides)}`, { method: 'POST' });
                        if (!response.ok) throw new Error('Failed to reset overrides');
                        
                        showAlert('All permission overrides cleared!', 'success');
                        closeOverridesModal();
                        renderStaffTable();
                    } catch (err) {
                        showAlert('Error resetting overrides: ' + err.message, 'error');
                    }
                }
            );
        }

        // Save permissions
        async function savePermissions() {
            try {
                const name = document.getElementById('editName')?.value;
                const role = document.getElementById('editRole')?.value;
                const department = document.getElementById('editDepartment')?.value;
                const status = document.getElementById('editStatus')?.value;

                // If we have edit form fields, save staff details
                if (name !== undefined) {
                    const emailParam = editingAdminEmail ? `?email=${encodeURIComponent(editingAdminEmail)}` : '';
                    const response = await fetch(`/api/staff/${editingAdminId}${emailParam}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            name: name.trim(),
                            role: role,
                            department: department.trim() === '' ? null : department.trim(),
                            status: status
                        })
                    });

                    if (response.ok) {
                        showAlert('Staff member updated successfully!', 'success');
                        closeEditModal();
                        // Reload staff data to reflect changes
                        try {
                            const adminsResponse = await fetch('/api/rbac/admins');
                            const adminsData = await adminsResponse.json();
                            allAdmins = adminsData.admins || [];
                            renderStaffTable();
                        } catch (e) {
                            renderStaffTable();
                        }
                    } else {
                        const error = await response.json();
                        showAlert(error.error || 'Error updating staff member', 'error');
                    }
                } else {
                    // Fallback to old permission-based saving
                    const checkboxes = document.querySelectorAll('.permission-check:checked');
                    const permissionIds = Array.from(checkboxes).map(cb => parseInt(cb.dataset.permissionId));

                    const response = await fetch('/api/rbac/admin/update-permissions', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ adminId: editingAdminId, permissionIds })
                    });

                    if (response.ok) {
                        showAlert('Permissions updated successfully!', 'success');
                        closeEditModal();
                        renderStaffTable();
                    } else {
                        const error = await response.json();
                        showAlert(error.message || 'Error updating permissions', 'error');
                    }
                }
            } catch (err) {
                showAlert('Error: ' + err.message, 'error');
            }
        }

        // Delete staff member
        async function deleteStaff(adminId, email) {
            showConfirmation(
                'Delete Staff Member',
                `Are you sure you want to delete ${email}? This action cannot be undone.`,
                async () => {
                    try {
                        // Delete using email parameter for better lookup
                        const response = await fetch(`/api/staff/${adminId}?email=${encodeURIComponent(email)}`, { 
                            method: 'DELETE',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        
                        if (response.ok) {
                            const data = await response.json();
                            showAlert('Staff member deleted successfully!', 'success');
                            
                            // Remove from frontend immediately, then reload to ensure sync
                            const rows = document.querySelectorAll('tbody tr');
                            rows.forEach(row => {
                                const emailCell = row.querySelector('.email-cell');
                                if (emailCell && emailCell.textContent.trim() === email) {
                                    row.remove();
                                }
                            });
                            
                            // Reload the full list after a short delay to ensure backend is updated
                            setTimeout(() => loadStaffMembers(), 500);
                        } else if (response.status === 404) {
                            showAlert('Staff member not found', 'error');
                            // Still reload to sync frontend with database
                            loadStaffMembers();
                        } else if (response.status === 403) {
                            showAlert('Cannot delete this staff member', 'error');
                        } else {
                            try {
                                const error = await response.json();
                                showAlert(error.error || 'Error deleting staff member', 'error');
                            } catch {
                                showAlert('Error deleting staff member', 'error');
                            }
                        }
                    } catch (err) {
                        showAlert('Error: ' + err.message, 'error');
                    }
                }
            );
        }

        // Open add staff modal
        async function openAddStaffModal() {
            document.getElementById('addStaffModal').classList.add('active');
            
            // Load departments for the dropdown
            try {
                const response = await fetch('/api/departments');
                if (!response.ok) {
                    console.error('Failed to fetch departments, status:', response.status);
                    return; // Still open the modal, just without departments
                }
                
